-- Fly system variables
local flyConnection
local flyBodyVelocity
local flyBodyGyro

local function cleanupFly()
	if flyConnection then
		flyConnection:Disconnect()
		flyConnection = nil
	end

	if flyBodyVelocity then
		flyBodyVelocity:Destroy()
		flyBodyVelocity = nil
	end

	if flyBodyGyro then
		flyBodyGyro:Destroy()
		flyBodyGyro = nil
	end

	local humanoid = getHumanoid()
	local rootPart = getRootPart()

	if humanoid then
		humanoid:SetStateEnabled(Enum.HumanoidStateType.Running, true)
		humanoid:SetStateEnabled(Enum.HumanoidStateType.Climbing, true)
		humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
		humanoid:SetStateEnabled(Enum.HumanoidStateType.Freefall, true)
		humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
	end

	if rootPart and rootPart:FindFirstChild("Running") then
		rootPart.Running.Volume = 0.65
	end
end

local function getFlyDirection(camera, humanoid)
	if humanoid.MoveDirection == Vector3.zero then
		return Vector3.zero
	end

	local cameraLook = camera.CFrame.LookVector
	local flattenedLook = Vector3.new(cameraLook.X, 0, cameraLook.Z)

	if flattenedLook.Magnitude <= 0 then
		return humanoid.MoveDirection.Unit
	end

	local cameraRelative =
		(
			camera.CFrame
			* CFrame.new(
				(
					CFrame.new(camera.CFrame.Position, camera.CFrame.Position + flattenedLook)
				):VectorToObjectSpace(humanoid.MoveDirection)
			)
		).Position - camera.CFrame.Position

	if cameraRelative.Magnitude <= 0 then
		return Vector3.zero
	end

	return cameraRelative.Unit
end

local function startFly()
	cleanupFly()

	local humanoid = getHumanoid()
	local rootPart = getRootPart()
	local character = getCharacter()

	if not humanoid or not rootPart or not character then
		return
	end

	flyBodyVelocity = Instance.new("BodyVelocity")
	flyBodyVelocity.Name = "FlyVelocity"
	flyBodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
	flyBodyVelocity.Velocity = Vector3.zero
	flyBodyVelocity.Parent = rootPart

	flyBodyGyro = Instance.new("BodyGyro")
	flyBodyGyro.Name = "FlyGyro"
	flyBodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
	flyBodyGyro.P = 9000
	flyBodyGyro.D = 500
	flyBodyGyro.CFrame = workspace.CurrentCamera.CFrame
	flyBodyGyro.Parent = rootPart

	humanoid:SetStateEnabled(Enum.HumanoidStateType.Running, false)
	humanoid:SetStateEnabled(Enum.HumanoidStateType.Climbing, false)
	humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
	humanoid:SetStateEnabled(Enum.HumanoidStateType.Freefall, false)

	if rootPart:FindFirstChild("Running") then
		rootPart.Running.Volume = 0
	end

	flyConnection = RunService.RenderStepped:Connect(function()
		if not featureStates.flyEnabled then
			return
		end

		if not character.Parent or not rootPart.Parent then
			return
		end

		local currentHumanoid = character:FindFirstChildOfClass("Humanoid")
		if not currentHumanoid then
			return
		end

		local camera = workspace.CurrentCamera
		currentHumanoid:ChangeState(Enum.HumanoidStateType.Physics)
		flyBodyGyro.CFrame = camera.CFrame

		local moveDirection = getFlyDirection(camera, currentHumanoid)

		if moveDirection == Vector3.zero then
			flyBodyVelocity.Velocity = Vector3.zero
		else
			flyBodyVelocity.Velocity = moveDirection * PROPERTIES.FlySpeed.value
		end
	end)
end

-- NoClip system
local function applyNoClipToCharacter(character)
	for _, part in ipairs(character:GetDescendants()) do
		if part:IsA("BasePart") then
			part.CanCollide = false
		end
	end
end

local function startNoClipLock()
	disconnectLock("NOCLIP")

	local function hookCharacter(character)
		applyNoClipToCharacter(character)

		addLockConnection("NOCLIP", character.DescendantAdded:Connect(function(desc)
			if propertyLocks.NOCLIP and desc:IsA("BasePart") then
				desc.CanCollide = false

				addLockConnection("NOCLIP", desc:GetPropertyChangedSignal("CanCollide"):Connect(function()
					if propertyLocks.NOCLIP and desc.Parent and desc.CanCollide ~= false then
						desc.CanCollide = false
					end
				end))
			end
		end))

		for _, part in ipairs(character:GetDescendants()) do
			if part:IsA("BasePart") then
				addLockConnection("NOCLIP", part:GetPropertyChangedSignal("CanCollide"):Connect(function()
					if propertyLocks.NOCLIP and part.Parent and part.CanCollide ~= false then
						part.CanCollide = false
					end
				end))
			end
		end
	end

	local character = getCharacter()
	if character then
		hookCharacter(character)
	end

	addLockConnection("NOCLIP", LocalPlayer.CharacterAdded:Connect(function(character)
		task.wait()
		if propertyLocks.NOCLIP then
			hookCharacter(character)
		end
	end))

	addLockConnection("NOCLIP", RunService.Stepped:Connect(function()
		if not propertyLocks.NOCLIP then
			return
		end

		local character = getCharacter()
		if character then
			applyNoClipToCharacter(character)
		end
	end))
end

-- WalkSpeed lock
local function startWalkSpeedLock()
	disconnectLock("WALKSPEED")

	local function apply()
		local humanoid = getHumanoid()
		if humanoid then
			humanoid.WalkSpeed = featureStates.doubleSpeedEnabled and PROPERTIES.DoubleSpeedValue.value or DEFAULTS.WalkSpeed
		end
	end

	apply()

	local humanoid = getHumanoid()
	if humanoid then
		addLockConnection("WALKSPEED", humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
			if propertyLocks.WALKSPEED then
				local target = featureStates.doubleSpeedEnabled and PROPERTIES.DoubleSpeedValue.value or DEFAULTS.WalkSpeed
				if humanoid.WalkSpeed ~= target then
					humanoid.WalkSpeed = target
				end
			end
		end))
	end

	addLockConnection("WALKSPEED", LocalPlayer.CharacterAdded:Connect(function()
		task.wait(0.2)
		if propertyLocks.WALKSPEED then
			startWalkSpeedLock()
		end
	end))

	addLockConnection("WALKSPEED", RunService.Heartbeat:Connect(function()
		if propertyLocks.WALKSPEED then
			apply()
		end
	end))
end

