-- Animations and Drag
local function animateIn()
	local tweenInfo = TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	TweenService:Create(MainFrame, tweenInfo, {
		Position = UDim2.fromScale(0.5, 0.5)
	}):Play()

	TweenService:Create(Shadow, tweenInfo, {
		Position = UDim2.fromScale(0.5, 0.5)
	}):Play()

	Title.TextTransparency = 1
	Title.Text = "WELCOME " .. LocalPlayer.Name

	TweenService:Create(Title, TweenInfo.new(0.3), {
		TextTransparency = 0
	}):Play()
end

local function animateOut()
	local tweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

	local frameTween = TweenService:Create(MainFrame, tweenInfo, {
		Position = UDim2.fromScale(0.5, 1.5)
	})
	local shadowTween = TweenService:Create(Shadow, tweenInfo, {
		Position = UDim2.fromScale(0.5, 1.5)
	})

	frameTween:Play()
	shadowTween:Play()

	frameTween.Completed:Wait()
	ScreenGui:Destroy()
end

local dragging = false
local dragStart
local dragStartPos

TitleBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		dragStartPos = MainFrame.Position
	end
end)

TitleBar.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		local newX = dragStartPos.X.Scale + (dragStartPos.X.Offset + delta.X) / workspace.CurrentCamera.ViewportSize.X
		local newY = dragStartPos.Y.Scale + (dragStartPos.Y.Offset + delta.Y) / workspace.CurrentCamera.ViewportSize.Y
		MainFrame.Position = UDim2.new(newX, 0, newY, 0)
	end
end)

CloseButton.MouseButton1Click:Connect(function()
	animateOut()
end)

-- Character respawn handling
LocalPlayer.CharacterAdded:Connect(function(character)
	task.wait(0.2)

	cleanupFly()

	local humanoid = character:FindFirstChildOfClass("Humanoid") or character:WaitForChild("Humanoid", 5)
	if humanoid then
		if featureStates.noJumpEnabled then
			humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)
		end

		if featureStates.lowGravityEnabled then
			workspace.Gravity = PROPERTIES.LowGravityValue.value
		else
			workspace.Gravity = DEFAULTS.Gravity
		end

		if featureStates.invisibleEnabled then
			for _, obj in ipairs(character:GetDescendants()) do
				if obj:IsA("BasePart") and obj.Name ~= "HumanoidRootPart" then
					obj.LocalTransparencyModifier = 1
				elseif obj:IsA("Decal") then
					obj.Transparency = 1
				end
			end
		end

		if featureStates.doubleSpeedEnabled then
			humanoid.WalkSpeed = PROPERTIES.DoubleSpeedValue.value
		end

		if featureStates.highJumpEnabled then
			humanoid.UseJumpPower = true
			humanoid.JumpPower = PROPERTIES.HighJumpPower.value
		end

		if featureStates.bigHipHeightEnabled then
			if originalHipHeight == nil then
				originalHipHeight = humanoid.HipHeight
			end
			humanoid.HipHeight = originalHipHeight + PROPERTIES.HipHeightOffset.value
		end

		if featureStates.platformStandEnabled then
			humanoid.PlatformStand = true
		end

		if featureStates.canRotateEnabled then
			humanoid.AutoRotate = true
		end

		if featureStates.sitEnabled then
			humanoid.Sit = true
		end
	end

	if featureStates.godModeEnabled then
		startGodMode()
	end

	if featureStates.chamsEnabled then
		updateChams()
	end
end)

animateIn()

