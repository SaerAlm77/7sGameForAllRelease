local function createSlider(parent, name, text, propertyKey, callback)
	local container = Instance.new("Frame")
	container.Name = name
	container.BackgroundColor3 = UI_CONFIG.Theme.Secondary
	container.BorderSizePixel = 0
	container.Size = UDim2.new(1, -20, 0, 70)
	container.Parent = parent

	local containerCorner = Instance.new("UICorner")
	containerCorner.CornerRadius = UDim.new(0, 6)
	containerCorner.Parent = container

	local label = Instance.new("TextLabel")
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.Gotham
	label.Position = UDim2.new(0, 12, 0, 5)
	label.Size = UDim2.new(0.7, 0, 0, 20)
	label.Text = text
	label.TextColor3 = UI_CONFIG.Theme.Text
	label.TextSize = 14
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = container

	local valueLabel = Instance.new("TextLabel")
	valueLabel.BackgroundTransparency = 1
	valueLabel.Font = Enum.Font.Gotham
	valueLabel.Position = UDim2.new(0.7, 0, 0, 5)
	valueLabel.Size = UDim2.new(0.3, -20, 0, 20)
	valueLabel.Text = tostring(PROPERTIES[propertyKey].value)
	valueLabel.TextColor3 = UI_CONFIG.Theme.Primary
	valueLabel.TextSize = 14
	valueLabel.TextXAlignment = Enum.TextXAlignment.Right
	valueLabel.Parent = container

	local slider = Instance.new("Frame")
	slider.BackgroundColor3 = UI_CONFIG.Theme.Background
	slider.BorderSizePixel = 0
	slider.Position = UDim2.new(0, 12, 0, 30)
	slider.Size = UDim2.new(1, -24, 0, 4)
	slider.Parent = container

	local sliderCorner = Instance.new("UICorner")
	sliderCorner.CornerRadius = UDim.new(1, 0)
	sliderCorner.Parent = slider

	local fill = Instance.new("Frame")
	fill.BackgroundColor3 = UI_CONFIG.Theme.Primary
	fill.BorderSizePixel = 0
	fill.Size = UDim2.new(0, 0, 1, 0)
	fill.Parent = slider

	local fillCorner = Instance.new("UICorner")
	fillCorner.CornerRadius = UDim.new(1, 0)
	fillCorner.Parent = fill

	local grabber = Instance.new("Frame")
	grabber.BackgroundColor3 = UI_CONFIG.Theme.Primary
	grabber.BorderSizePixel = 0
	grabber.Position = UDim2.new(0, 0, 0.5, -8)
	grabber.Size = UDim2.new(0, 16, 0, 16)
	grabber.Parent = slider

	local grabberCorner = Instance.new("UICorner")
	grabberCorner.CornerRadius = UDim.new(1, 0)
	grabberCorner.Parent = grabber

	local data = PROPERTIES[propertyKey]
	local minVal = data.min
	local maxVal = data.max
	local step = data.step
	local currentVal = data.value

	local function updateSlider()
		local percent = (currentVal - minVal) / (maxVal - minVal)
		fill.Size = UDim2.new(percent, 0, 1, 0)
		grabber.Position = UDim2.new(percent, -8, 0.5, -8)
		valueLabel.Text = tostring(currentVal)
	end

	updateSlider()

	local dragging = false

	local function onInput(input)
		if not dragging then return end
		local relativeX = math.clamp((input.Position.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
		currentVal = minVal + (maxVal - minVal) * relativeX
		currentVal = math.round(currentVal / step) * step
		currentVal = math.clamp(currentVal, minVal, maxVal)
		PROPERTIES[propertyKey].value = currentVal
		updateSlider()
		if callback then
			callback(currentVal)
		end
	end

	grabber.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			onInput(input)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			onInput(input)
		end
	end)

	return container
end

