				if newName == "LeftShift" then newName = "Shift" end
				keyButton.Text = newName
				keyButton.BackgroundColor3 = UI_CONFIG.Theme.Background
				listening = false
				conn:Disconnect()

				-- Reconnect keybind
				if keybindConnections[featureName] then
					keybindConnections[featureName]:Disconnect()
				end
				local newConn = UserInputService.InputBegan:Connect(function(inp, gp)
					if gp then return end
