		if not latestTextBox or not latestTextBox.Parent then
			return
		end

		if newId == "" or newId == lastShownId then
			return
		end

		previousShownId = lastShownId
		lastShownId = newId

		latestTextBox.Text = lastShownId or ""
		previousTextBox.Text = previousShownId or ""
	end

	local function connectCharacter(character)
		if animationThiefConnection then
			animationThiefConnection:Disconnect()
			animationThiefConnection = nil
		end

		if not character then
			return
		end

		local humanoid = character:FindFirstChildOfClass("Humanoid") or character:WaitForChild("Humanoid", 5)
		if not humanoid then
			return
		end

		animationThiefConnection = humanoid.AnimationPlayed:Connect(function(track)
			local animation = track.Animation
			if animation and animation.AnimationId and animation.AnimationId ~= "" then
				local cleanId = extractAnimationId(animation.AnimationId)
				updateBoxes(cleanId)
			end
		end)
	end

	connectCharacter(getCharacter())

	animationThiefCharacterConnection = LocalPlayer.CharacterAdded:Connect(function(character)
		task.wait(0.2)
		connectCharacter(character)
	end)
end

-- Keybind System
local keybindConnections = {}

local function toggleFeature(featureName)
	local state = featureStates[featureName]
	local newState = not state
	featureStates[featureName] = newState

	-- Update UI toggle buttons if they exist
	local toggleButton = _G["toggle_" .. featureName]
	if toggleButton then
		toggleButton(newState)
	end

	-- Execute feature toggle logic
	if featureName == "flyEnabled" then
		if newState then
			startFly()
		else
			cleanupFly()
		end
	elseif featureName == "noClipEnabled" then
		setLockState("NOCLIP", newState)
		if newState then
			startNoClipLock()
		else
			local character = getCharacter()
			if character then
				for _, part in ipairs(character:GetDescendants()) do
					if part:IsA("BasePart") then
						part.CanCollide = true
					end
				end
			end
		end
	elseif featureName == "doubleSpeedEnabled" then
		setLockState("WALKSPEED", newState)
		if newState then
			startWalkSpeedLock()
		else
			local humanoid = getHumanoid()
			if humanoid then
				humanoid.WalkSpeed = DEFAULTS.WalkSpeed
			end
		end
	elseif featureName == "espEnabled" then
		if newState then
			startESP()
		else
			clearESP()
		end
	elseif featureName == "highJumpEnabled" then
		setLockState("JUMPPOWER", newState)
		if newState then
			startJumpPowerLock()
		else
			local humanoid = getHumanoid()
			if humanoid then
				humanoid.UseJumpPower = true
				humanoid.JumpPower = DEFAULTS.JumpPower
			end
		end
	elseif featureName == "lowGravityEnabled" then
		setLockState("GRAVITY", newState)
		startGravityLock()
	elseif featureName == "bigHipHeightEnabled" then
		setLockState("HIPHEIGHT", newState)
		startHipHeightLock()
	elseif featureName == "invisibleEnabled" then
		updateInvisible()
	elseif featureName == "godModeEnabled" then
		if newState then
			startGodMode()
		else
			stopGodMode()
		end
	elseif featureName == "noJumpEnabled" then
		setLockState("NOJUMP", newState)
		startNoJumpLock()
	elseif featureName == "platformStandEnabled" then
		setLockState("PLATFORMSTAND", newState)
		startPlatformStandLock()
	elseif featureName == "canRotateEnabled" then
		setLockState("AUTOROTATE", true)
		startAutoRotateLock()
	elseif featureName == "sitEnabled" then
		updateSit()
	elseif featureName == "chamsEnabled" then
		updateChams()
	elseif featureName == "animationThiefEnabled" then
		if newState then
			startAnimationThief()
		else
			cleanupAnimationThief()
		end
	end
end

local function setupKeybinds()
	for featureName, bindData in pairs(KEYBINDS) do
		local connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
			if gameProcessed then
				return
			end

			if input.KeyCode == bindData.key and bindData.enabled then
				toggleFeature(featureName)
			end
		end)
		keybindConnections[featureName] = connection
	end
end

