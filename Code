-- ESP system
local espMarkers = {}
local espPlayerAddedConnection
local espCharacterConnections = {}

local function clearESP()
	for _, conn in pairs(espCharacterConnections) do
		if conn then
			conn:Disconnect()
		end
	end
	espCharacterConnections = {}

	if espPlayerAddedConnection then
		espPlayerAddedConnection:Disconnect()
		espPlayerAddedConnection = nil
	end

	for _, markers in pairs(espMarkers) do
		if markers.billboard then
			markers.billboard:Destroy()
		end
		if markers.highlight then
			markers.highlight:Destroy()
		end
	end
	espMarkers = {}
end

local function startESP()
	clearESP()

	local function applyESP(player, character)
		if player == LocalPlayer or not character then
			return
		end

		local head = character:FindFirstChild("Head")
		if not head then
			return
		end

		if espMarkers[player] then
			if espMarkers[player].billboard then
				espMarkers[player].billboard:Destroy()
			end
			if espMarkers[player].highlight then
				espMarkers[player].highlight:Destroy()
			end
		end

		local billboard = Instance.new("BillboardGui")
		billboard.Name = "ESP_" .. player.Name
		billboard.Size = UDim2.new(0, 100, 0, 40)
		billboard.Adornee = head
		billboard.AlwaysOnTop = true
		billboard.Parent = head

		local nameLabel = Instance.new("TextLabel")
		nameLabel.Size = UDim2.new(1, 0, 1, 0)
		nameLabel.BackgroundTransparency = 1
		nameLabel.Text = player.Name
		nameLabel.TextColor3 = UI_CONFIG.Theme.Primary
		nameLabel.TextStrokeTransparency = 0.3
		nameLabel.TextScaled = true
		nameLabel.Font = Enum.Font.GothamBold
		nameLabel.Parent = billboard

		local highlight = Instance.new("Highlight")
		highlight.FillColor = UI_CONFIG.Theme.Primary
		highlight.FillTransparency = 0.7
		highlight.OutlineTransparency = 0.5
		highlight.Parent = character

		espMarkers[player] = {
			billboard = billboard,
			highlight = highlight
		}
	end

	local function watchPlayer(player)
		if player == LocalPlayer then
			return
		end

		if player.Character then
			applyESP(player, player.Character)
		end

		espCharacterConnections[player] = player.CharacterAdded:Connect(function(character)
			task.wait(0.3)
			if featureStates.espEnabled then
				applyESP(player, character)
			end
		end)
	end

	for _, player in ipairs(Players:GetPlayers()) do
		watchPlayer(player)
	end

	espPlayerAddedConnection = Players.PlayerAdded:Connect(watchPlayer)
end

-- God Mode
local godModeForceField

local function startGodMode()
	local character = getCharacter()
	local humanoid = getHumanoid()
	if not character or not humanoid then
		return
	end

	humanoid.MaxHealth = math.huge
	humanoid.Health = humanoid.MaxHealth

	if not godModeForceField or not godModeForceField.Parent then
		godModeForceField = Instance.new("ForceField")
		godModeForceField.Visible = true
		godModeForceField.Parent = character
	end
end

local function stopGodMode()
	local humanoid = getHumanoid()
	if humanoid then
		humanoid.MaxHealth = 100
		humanoid.Health = math.min(humanoid.Health, humanoid.MaxHealth)
	end

	if godModeForceField then
		godModeForceField:Destroy()
		godModeForceField = nil
	end
end

-- Invisible
local function updateInvisible()
	local character = getCharacter()
	if not character then
		return
	end

	for _, obj in ipairs(character:GetDescendants()) do
		if obj:IsA("BasePart") and obj.Name ~= "HumanoidRootPart" then
			obj.LocalTransparencyModifier = featureStates.invisibleEnabled and 1 or 0
		elseif obj:IsA("Decal") then
			obj.Transparency = featureStates.invisibleEnabled and 1 or 0
		end
	end
end

-- Chams
local function updateChams()
	local character = getCharacter()
	if character then
		local highlight = character:FindFirstChild("LocalChamsHighlight")

		if featureStates.chamsEnabled and not highlight then
			local newHighlight = Instance.new("Highlight")
			newHighlight.Name = "LocalChamsHighlight"
			newHighlight.FillColor = UI_CONFIG.Theme.Primary
			newHighlight.FillTransparency = 0.5
			newHighlight.OutlineTransparency = 0.2
			newHighlight.Parent = character
		elseif not featureStates.chamsEnabled and highlight then
			highlight:Destroy()
		end
	end
end

-- Sit
local function updateSit()
	local humanoid = getHumanoid()
	if humanoid then
		humanoid.Sit = featureStates.sitEnabled
	end
end

