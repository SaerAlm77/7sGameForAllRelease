			return
		end

		if draggingThief and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = input.Position - dragStartThief
			frame.Position = UDim2.new(
				startPosThief.X.Scale,
				startPosThief.X.Offset + delta.X,
				startPosThief.Y.Scale,
				startPosThief.Y.Offset + delta.Y
			)
		end
	end)

