local function getCharacter()
	return LocalPlayer.Character
end

local propertyLocks = {}
local lockConnections = {}

local function disconnectLock(name)
	if lockConnections[name] then
		for _, conn in ipairs(lockConnections[name]) do
			if conn then
				conn:Disconnect()
			end
		end
		lockConnections[name] = nil
	end
end

local function setLockState(name, enabled)
	propertyLocks[name] = enabled
	if not enabled then
		disconnectLock(name)
	end
end

local function addLockConnection(name, conn)
	lockConnections[name] = lockConnections[name] or {}
	table.insert(lockConnections[name], conn)
end

