-- HipHeight lock
local originalHipHeight = nil

local function cacheHumanoidDefaults()
	local humanoid = getHumanoid()
	if humanoid then
		if originalHipHeight == nil then
			originalHipHeight = humanoid.HipHeight
		end
	end
end

cacheHumanoidDefaults()

local function startHipHeightLock()
	disconnectLock("HIPHEIGHT")

	local function apply()
		local humanoid = getHumanoid()
		if humanoid then
			if originalHipHeight == nil then
				originalHipHeight = humanoid.HipHeight
			end

			local target = featureStates.bigHipHeightEnabled and (originalHipHeight + PROPERTIES.HipHeightOffset.value) or originalHipHeight
			if math.abs(humanoid.HipHeight - target) > 0.01 then
				humanoid.HipHeight = target
			end
		end
	end

	apply()

	local humanoid = getHumanoid()
	if humanoid then
		addLockConnection("HIPHEIGHT", humanoid:GetPropertyChangedSignal("HipHeight"):Connect(function()
			if propertyLocks.HIPHEIGHT then
				apply()
			end
		end))
	end

	addLockConnection("HIPHEIGHT", LocalPlayer.CharacterAdded:Connect(function()
		task.wait(0.3)
		if propertyLocks.HIPHEIGHT then
			startHipHeightLock()
		end
	end))

	addLockConnection("HIPHEIGHT", RunService.Heartbeat:Connect(function()
		if propertyLocks.HIPHEIGHT then
			apply()
		end
	end))
end

